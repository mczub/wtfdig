{
  "name": "wtfdig",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "check": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun svelte-kit sync && bun --bun svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "bun --bun prettier --check . && bun --bun eslint .",
    "format": "bun --bun prettier --write .",
    "test": "vitest run tests/",
    "test:tier1": "vitest run tests/validate/tier1.test.ts",
    "test:unit": "vitest run tests/unit/"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.13",
    "@types/eslint": "^9.6.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-preprocess-import-assets": "^1.1.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.21",
    "vitest": "^4.1.5"
  },
  "type": "module",
  "dependencies": {
    "@lucide/svelte": "^1.14.0",
    "@tailwindcss/vite": "^4.2.4",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
